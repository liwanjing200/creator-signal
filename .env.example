# Web app (safe for the browser; configure these in Vercel)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY

# Local crawler/transcription scripts only. Never add this to Vercel.
SUPABASE_SERVICE_ROLE_KEY=YOUR_LOCAL_ONLY_SERVICE_ROLE_KEY

# Local runtime defaults
LOCAL_DATA_DIR=./local-data
WHISPER_CPP_MODEL=small
WHISPER_CPP_MODEL_SMALL=
WHISPER_CPP_MODEL_MEDIUM=
MLX_WHISPER_MODEL_SMALL=mlx-community/whisper-small-mlx
MLX_WHISPER_MODEL_MEDIUM=mlx-community/whisper-medium-mlx
CHROME_CDP_URL=http://127.0.0.1:9222
YTDLP_COOKIES_FROM_BROWSER=chrome
X_BEARER_TOKEN=your-local-x-api-v2-bearer-token
